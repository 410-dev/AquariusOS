{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "source": "/usr/share/fastfetch/logos/{{RESOURCE_NAME}}.txt",
    "type": "file",
    "color": {
      "1": "blue",      // ${c1} 색상
      "2": "cyan",      // ${c2} 색상
      "3": "white"      // ${c3} 색상
    },
    "padding": {
      "top": 1,
      "left": 2
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "de",
    "wm",
    "wmtheme",
    "theme",
    "icons",
    "font",
    "cursor",
    "terminal",
    "terminalfont",
    "cpu",
    "gpu",
    "memory",
    "swap",
    "disk",
    "localip",
    "battery",
    "poweradapter",
    "locale",
    "break",
    "colors"
  ]
}