{
    "StructType": "BuildRecipe",
    "StructVersion": 2,

    // 빌드 메타정보
    "Name": "AquariusOS",
    "Codename": "Genesis",
    "ReleaseType": "Experimental",
    "Upstream": "Ubuntu",

    // 경로 설정
    "Source": ".",
    "Temporary": "tmp",
    "OutputDir": "build",
    "SourceExclude": [
        "tmp",
        "build",
        "build.sh",
        "README.md",
        ".*",
//        ".git",
//        ".github",
        //        ".venv",
        //        ".vscode",
        //        ".idea",
        "assets",
        "doc"
    ],

    // 동적 변수
    "Variables": {
        "BUILD_DATE": { "$run": "date +%y%m.%d.%H%M%S" },
        "VERSION":    { "$run": "date +%y%m.%d.%H%M" },
        "RUNNER":     { "$run": "whoami" },

        // Path 변수
        "CMDS":           "/usr/bin",
        "SYS_CMDS":       "/usr/bin",
        "USER_APPS":      "/applications",
        "AQUAROOT":       "/usr/share/aqua",
        "OSCORE":         "/usr/share/aqua/sys",
        "SYS_SERVICES":   "/usr/share/aqua/sys/services",
        "OPT_SERVICES":   "/usr/share/aqua/services",
        "SYS_FRAMEWORKS": "/usr/lib",
        "SYS_PYLIBS":     "/usr/lib/python3/dist-packages",
        "SYS_SHELLLIBS":  "/usr/share/aqua/sys/lib/shell",
        "EXT_LIBS":       "/usr/share/aqua/lib",
        "RESOURCES":      "/usr/share/aqua/share",
        "SYS_APPS":       "/usr/share/aqua/sys/applications",
        "OPT_LIBS":       "/usr/share/aqua/lib",
        "FEATURES":       "/usr/share/aqua/features",
        "AQUA_VFS_ROOT":  "/usr/share/aqua/vfs",
        "REG_GLOBAL":     "/etc/aqua/registry",
        "VAR_ROOT":       "/var/aqua",
    },

    // 소스코드 텍스트 치환
    // 소스 파일 안의 {{VARIABLE}} 을 변수값으로 치환
    "Substitutions": {
        "Delimiter": ["{{", "}}"],
        "ApplyToAllNonBinary": true,
        "Apply": [
            "**/*.sh", "**/*.py",
            "**/*.json", "**/*.conf"
        ],
        "Skip": [
            "**/*.jar", "**/*.class",
            "**/*.png", "**/*.jpg",
            "**/*.zip", "**/*.tar",
        ]
    },

    // 전체 매핑 (모든 에디션 공통)
    // Include 인데 여기 없으면 빌드 실패
    "Mapping": {
        "root-skeleton":           "/",
        "branding":                "/",         // 에디션별 오버라이드
        "system/core":             "/usr/share/aqua/sys",
        "system/commands":         "/usr/bin",
        "system/services":         "/usr/share/aqua/sys/services",
        "system/preboot":          "/usr/share/aqua/boot/preboot",
        "frameworks":              "/usr/lib/aqua/frameworks",
        "libraries/system/python": "/usr/lib/python3/dist-packages",
        "libraries/system/java":   "/usr/lib/jvm/default-java",
        "libraries/system/shell":  "/usr/lib/aqua/sys/lib/shell",
        "libraries/extension":     "/usr/lib/aqua/lib",
        "resources":               "/usr/share/aqua/share",
        "runtime-skeleton":        "/usr/share/aqua",
        "applications/system":     "/usr/share/aqua/sys/applications",
        "applications/user":       "/applications",
        "features":                "/usr/share/aqua/features",
    },

    // 전처리기
    "Preprocessor": {
        "PathReplacements": {
            "aisp-":            "aqua-",
            "com.acadia.aisp.": "me.hysong.aqua.",
            "com.acadia.":      "me.hysong.",
            "aisp":             "aqua",
            "AISP":             "AquariusOS"
        },
        "Blacklist": [".DS_Store", "Thumbs.db"],
        "SetExecutables": [
            "*.sh", "*.py",
            "preinst", "postinst", "prerm", "postrm"
        ],
    },

    // 빌드 우선순위
    "BuildPriority": [
        "libraries/extension/java/libcodablejson",
        "libraries/extension/java/libcodablejdbc",
        "libraries/system",
        "libraries/extension",
    ],

    // 오류 무시
    "IgnoreErrors": {
        "FileNotFoundError": [
            "libraries/extension/java/libcodablejdbc/lib/libcodablejson"
        ]
    },

    "PostBuild": [
        ["sudo", "chown", "-R", "root:root",       "{{Temporary}}/step_1"],
        ["sudo", "chmod", "-R", "755",             "{{Temporary}}/step_1"],
        ["sudo", "dpkg-deb", "--build",            "{{Temporary}}/step_1"],
        ["sudo", "chown", "{{RUNNER}}:{{RUNNER}}", "{{Temporary}}/step_1.deb"],
        ["sudo", "chmod", "644",                   "{{Temporary}}/step_1.deb"],
        ["sudo", "chown", "-R", "{{RUNNER}}:{{RUNNER}}", "{{Temporary}}/step_1"],
        ["mv", "{{Temporary}}/step_1.deb",         "{{Output}}/{{EDITION_FILENAME}}.deb"],
        ["rm", "-rf", "{{Temporary}}"],
    ],

    // 패키징 공통 설정
    "Output": {
        "Patterns": ["*.deb"],
    }
}