[Unit]
Description=AquariusOS PID Files Purger On Boot
DefaultDependencies=no
After=local-fs.target
Before=multi-user.target

[Service]
Type=oneshot
User=root
WorkingDirectory={{AQUAROOT}}/homes/root
ExecStart=/bin/sh -c '[ -d {{AQUAROOT}}/homes/root/systemd/pid ] && rm -rf {{AQUAROOT}}/homes/root/systemd/pid/* || mkdir -p {{AQUAROOT}}/homes/root/systemd/pid'

[Install]
WantedBy=multi-user.target
